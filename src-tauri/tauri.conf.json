{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VirtualAudioMix",
  "version": "0.1.0",
  "identifier": "dev.virtual-audio-mix.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:ui",
    "beforeBuildCommand": "npm run build:ui",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VirtualAudioMix",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "Bruno Del piero",
    "copyright": "Copyright (c) 2026 Bruno Del piero",
    "license": "MIT",
    "licenseFile": "installer/LICENSE-VAM.txt",
    "category": "Music",
    "homepage": "https://github.com/8run0d/VirtualAudioMix",
    "resources": ["resources/driver/x64/*", "resources/installer/*"],
    "shortDescription": "Routeur et mixeur audio virtuel open source.",
    "longDescription": "VirtualAudioMix est une application desktop open source sous licence MIT, avec droits d'utilisation, de modification et de redistribution accordés. Développé par Bruno Del piero.",
    "icon": ["icons/icon.ico", "icons/icon.png", "icons/32x32.png", "icons/128x128.png", "icons/256x256.png"],
    "windows": {
      "nsis": {
        "languages": ["French", "English"],
        "displayLanguageSelector": true,
        "customLanguageFiles": {
          "French": "installer/languages/French.nsh",
          "English": "installer/languages/English.nsh"
        },
        "installMode": "both",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "headerImage": "installer/assets/nsis-header.bmp",
        "sidebarImage": "installer/assets/nsis-sidebar.bmp",
        "uninstallerHeaderImage": "installer/assets/nsis-header.bmp",
        "installerHooks": "installer/hooks/vam-installer-hooks.nsh",
        "startMenuFolder": "VirtualAudioMix"
      },
      "wix": {
        "language": "fr-FR",
        "fragmentPaths": ["installer/wix/vam-msi-hooks.wxs"],
        "componentRefs": ["VamMsiInstallerPreferences"],
        "bannerPath": "installer/assets/wix-banner.bmp",
        "dialogImagePath": "installer/assets/wix-dialog.bmp"
      }
    }
  }
}
